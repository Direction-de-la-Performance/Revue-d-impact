rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture/écriture pour tout utilisateur connecté avec le compte d'accès partagé
    // (voir docs/js/config.js > ACCES_EMAIL et README > mise en route).
    // À durcir en production : réserver l'écriture des cibles à la Direction de la Performance
    // via custom claims (request.auth.token.role == 'dp').
    match /saisies/{doc} {
      allow read, write: if request.auth != null;
    }
    match /saisies_historique/{doc} {
      // Écriture ouverte : chaque enregistrement d'une remontée (par n'importe quel utilisateur)
      // doit pouvoir archiver une copie. Lecture (liste des versions, restauration) réservée
      // au compte administrateur (voir docs/js/config.js > ADMIN_EMAIL).
      allow write: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == "admin@revue-impact.ft";
    }
    match /resultats/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // alimenté via admin-import.html
    }
    match /cibles_financeurs/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // TODO: restreindre au rôle 'dp'
    }
    match /ref_agences/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // alimenté via admin-import-referentiel.html
    }
    match /ref_dds/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // alimenté via admin-import-referentiel.html
    }
  }
}
