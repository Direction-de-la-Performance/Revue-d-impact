rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture pour tout utilisateur authentifié (auth anonyme activée côté app).
    // À durcir en production : réserver l'écriture des cibles à la Direction de la Performance
    // via custom claims (request.auth.token.role == 'dp').
    match /saisies/{doc} {
      allow read, write: if request.auth != null;
    }
    match /resultats/{doc} {
      allow read: if request.auth != null;
      allow write: if false; // alimenté par script d'import (Admin SDK)
    }
    match /cibles_financeurs/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // TODO: restreindre au rôle 'dp'
    }
  }
}
